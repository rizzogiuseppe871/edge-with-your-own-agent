{
  "manifest_version": 3,
  "name": "Reasonix on Edge",
  "version": "1.0.0",
  "description": "AI 驱动的浏览器自动化 —— Reasonix 通过 Side Panel 操控网页 DOM",
  "author": "rizzogiuseppe871",
  "homepage_url": "https://github.com/rizzogiuseppe871/reasonix-on-edge",

  "permissions": [
    "sidePanel",
    "scripting",
    "activeTab",
    "storage",
    "downloads",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_title": "Reasonix on Edge",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["reasonix-content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
